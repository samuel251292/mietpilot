# Copy this file to .env.production.local for Docker/Synology deployments,
# or use the same keys in Vercel Project Settings -> Environment Variables.
# Do not commit real secrets.

# Public URL behind your reverse proxy, for example https://app.example.com
NEXT_PUBLIC_APP_URL=

# MVP defaults for Docker/Synology/Vercel test deployments.
# Keep local/demo until Supabase Auth/DB/Storage are deliberately activated.
NEXT_PUBLIC_AUTH_PROVIDER=demo
NEXT_PUBLIC_CASE_REPOSITORY=local
NEXT_PUBLIC_FILE_STORAGE=local

# Supabase preparation. Fill only when a Supabase testdeployment is intentional.
# First Supabase test strategy:
# NEXT_PUBLIC_AUTH_PROVIDER=demo
# NEXT_PUBLIC_CASE_REPOSITORY=supabase
# NEXT_PUBLIC_FILE_STORAGE=supabase
# Supabase Auth should be activated later in a separate step.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side OCR/export configuration.
OCR_LANGUAGE=deu

# Optional. Required only for real DOCX->PDF conversion.
CONVERTAPI_SECRET=
